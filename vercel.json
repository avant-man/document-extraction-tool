{
  "rewrites": [{ "source": "/api/:path*", "destination": "/api/index" }],
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": [
        "node_modules/tesseract.js-core/**/*.wasm",
        "backend/node_modules/tesseract.js-core/**/*.wasm"
      ]
    }
  }
}
