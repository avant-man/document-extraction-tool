{
  "rewrites": [{ "source": "/api/:path*", "destination": "/api/index" }],
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300,
      "includeFiles": "**/{pdfjs-dist,tesseract.js-core,@napi-rs/canvas}/**"
    }
  }
}
