ANTHROPIC_API_KEY=your_key_here
# Required for server-side Blob operations: delete after extract, and get() when reading the uploaded PDF
BLOB_READ_WRITE_TOKEN=your_token_here
# Optional. Only if you add handleUpload onUploadCompleted: public HTTPS URL Vercel can POST to (e.g. https://your-app.vercel.app/api/blob-upload). Not used for local-only webhooks without a tunnel.
# VERCEL_BLOB_CALLBACK_URL=
NODE_ENV=development
# Backend: debug | info | warn | error (default info)
LOG_LEVEL=info
# Set true to include err stacks in logs when NODE_ENV=production
LOG_STACK=
VITE_API_BASE_URL=http://localhost:3001
