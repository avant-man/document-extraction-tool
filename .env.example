ANTHROPIC_API_KEY=your_key_here
# Required for server-side Blob operations: delete after extract, and get() when reading the uploaded PDF
BLOB_READ_WRITE_TOKEN=your_token_here
# Optional. Only if you add handleUpload onUploadCompleted: public HTTPS URL Vercel can POST to (e.g. https://your-app.vercel.app/api/blob-upload). Not used for local-only webhooks without a tunnel.
# VERCEL_BLOB_CALLBACK_URL=
NODE_ENV=development
# Backend: debug | info | warn | error (default info)
LOG_LEVEL=info
# Set true to include err stacks in logs when NODE_ENV=production
LOG_STACK=
VITE_API_BASE_URL=http://localhost:3001

# Extraction / Claude input sizing (optional)
# EXTRACTION_INPUT_TOKEN_BUDGET=175000
# EXTRACTION_CHARS_PER_TOKEN=3.5
# Max Claude calls when a document is split into page batches (default 48)
# EXTRACTION_MAX_BATCHES=48
# Cap pages per batch (smaller → shorter LLM JSON per call). Unset = no cap, token budget only.
# When set, if the PDF has more pages than this value the pipeline uses multi-call batching even
# when the full document is under EXTRACTION_INPUT_TOKEN_BUDGET (avoids one huge JSON / max_tokens).
# EXTRACTION_MAX_PAGES_PER_BATCH=3

# --- Scan / image-only PDFs (required for non-selectable text) ---
# Default in code is none (no OCR). Set tesseract on server + redeploy for scan-only plans.
# OCR_ENGINE=tesseract
# OCR_SPARSE_CHAR_THRESHOLD=80
# OCR_SPARSE_MIN_ALNUM_RATIO=0.12
# If total native chars across all pages is below this, every page is an OCR candidate (tesseract only).
# AUTO_OCR_NATIVE_TOTAL_CHARS_THRESHOLD=500
# OCR_RENDER_SCALE=1.75
# OCR_MAX_PAGES=60
